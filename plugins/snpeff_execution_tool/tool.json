{
  "name": "snpeff_execution_tool",
  "description": "Run local SnpEff annotation on a VCF using the installed Java runtime and local SnpEff genome databases.",
  "task": "variant-annotation-execution",
  "modality": "genomics",
  "approval_required": false,
  "source": "local",
  "routing": {
    "trigger_keywords": ["snpeff", "snp eff"],
    "execution_intents": ["run", "execute", "annotate", "use", "실행", "돌려", "주석", "사용"],
    "requires_source_vcf": true,
    "question_argument": "none",
    "result_slot": "snpeff_result",
    "execution_mode": "direct_endpoint"
  },
  "orchestration": {
    "tool_kind": "execution",
    "default_stage": "post-annotation",
    "depends_on": ["annotation_tool"],
    "consumes": ["vcf_path"],
    "produces": ["snpeff_result"],
    "priority": 80,
    "on_demand": true
  },
  "runtime": {
    "host_compatible": ["cpu"],
    "requires_gpu": false,
    "allow_cpu_fallback": true,
    "estimated_runtime_sec": 8
  }
}
