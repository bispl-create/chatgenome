{
  "name": "clinical_coverage_tool",
  "description": "Summarizes annotation completeness across ClinVar, gnomAD, gene, and HGVS fields.",
  "task": "clinical-coverage",
  "modality": "genomics",
  "approval_required": false,
  "source": "plugin",
  "workflow_binding": {
    "source_type": "vcf",
    "input_map": {
      "annotations": "$annotations"
    },
    "result_path": "clinical_coverage_summary",
    "transform": "detailed_count_summary_list",
    "used_tools_label": "clinical_coverage_tool",
    "fallback_transform": "clinical_coverage_local"
  }
}
