{
  "name": "summary_stats_review_tool",
  "entrypoint": "plugins.summary_stats_review_tool.logic:execute",
  "description": "Analyze a summary-statistics file into detected columns, inferred mappings, preview rows, and draft intake guidance.",
  "task": "summary-stats-review",
  "modality": "genomics",
  "approval_required": false,
  "source": "plugin",
  "workflow_binding": {
    "source_type": "summary_stats",
    "input_map": {
      "source_stats_path": "$source_stats_path",
      "file_name": "$file_name",
      "genome_build": "$genome_build",
      "trait_type": "$trait_type"
    },
    "result_path": "analysis",
    "transform": "summary_stats_response",
    "used_tools_label": "summary_stats_review_tool"
  }
}
