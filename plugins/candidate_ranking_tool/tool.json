{
  "name": "candidate_ranking_tool",
  "entrypoint": "plugins.candidate_ranking_tool.logic:execute",
  "description": "Ranks annotated variants into a short candidate review list using clinical and ROH-aware heuristics.",
  "task": "candidate-ranking",
  "modality": "genomics",
  "approval_required": false,
  "source": "plugin",
  "workflow_binding": {
    "source_type": "vcf",
    "input_map": {
      "annotations": "$annotations",
      "roh_segments": "$roh_segments",
      "limit": 8
    },
    "result_path": "candidate_variants",
    "transform": "ranked_candidate_list",
    "used_tools_label": "candidate_ranking_tool",
    "fallback_transform": "candidate_ranking_local"
  }
}
