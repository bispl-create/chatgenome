{
  "name": "filtering_view_tool",
  "entrypoint": "plugins.filtering_view_tool.logic:execute",
  "description": "Builds searchable variant-table summary metrics for the filtering and triage view.",
  "task": "filtering-view",
  "modality": "genomics",
  "approval_required": false,
  "source": "plugin",
  "workflow_binding": {
    "source_type": "vcf",
    "input_map": {
      "annotations": "$annotations"
    },
    "result_path": "filtering_summary",
    "transform": "detailed_count_summary_list",
    "used_tools_label": "filtering_view_tool",
    "fallback_transform": "filtering_view_local"
  }
}
